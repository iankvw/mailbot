{
  "name": "mailbot",
  "main": "index.js",
  "compatibility_date": "2026-04-11",
  "vars": {
    "ROUTING_MAP": {
      "example@mydomain.com": {
        "webhookUrl": "https://discord.com/api/webhooks/YOUR_DISCORD_WEBHOOK_URL",
        "forwardEmail": "your_email@example.com"
      },
      "catch_all": {
        "webhookUrl": "https://discord.com/api/webhooks/YOUR_DEFAULT_WEBHOOK_URL",
        "forwardEmail": "default_email@example.com"
      }
    }
  }
}